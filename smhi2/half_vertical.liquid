{%- assign hours = "09, 13, 18" | split: ", " -%}
{%- assign show = 3 -%}
{%- assign type = ", Snö, Snöbland, Regn, Dugg, Undk regn, Undk dugg" | split: ", " -%}
{%- assign symbol = ", Klar himmel, Nästan klar himmel, Varierande molnighet, Halvklart, Molnig himmel, Mulet, Dimma, Lätta regnskurar, Måttliga regnskurar, Kraftiga regnskurar, Åskväder, Lätta snöslaskskurar, Måttliga snöslaskskurar, Kraftiga snöslaskskurar, Lätta snöbyar, Måttliga snöbyar, Kraftiga snöbyar, Lätt regn, Måttligt regn, Kraftigt regn, Åska, Lätt snöslask, Måttlig snöslask, Kraftig snöslask, Lätt snöfall, Måttligt snöfall, Kraftigt snöfall" | split: ", " -%}
{%- assign icons = ", ☀️, 🌤️, ⛅, 🌥️, 🌥️, ☁️, 🌫️, 🌦️, 🌧️, 🌧️, ⛈️, 🌨️, 🌨️, 🌨️, 🌨️, ❄️, ❄️, 🌦️, 🌧️, 🌧️, ⛈️, 🌨️, 🌨️, 🌨️, ❄️, ❄️, ❄️" | split: ", " -%}
{%- assign days_l = ", Måndag, Tisdag, Onsdag, Torsdag, Fredag, Lördag, Söndag" | split: ", " -%}
{%- assign days = ", Mån, Tis, Ons, Tors, Fre, Lör, Sön" | split: ", " -%}
{%- assign i = 0 -%}

{%- for series in timeSeries -%}
  {%- assign validtimetz = series.validTime | date: "%s" | plus: trmnl.user.utc_offset -%}
  {%- for param in series.parameters -%}
    {%- assign value = param.values[0] | plus: 0 -%}
    {%- if param.name == "t" -%}{%- assign temp = value | round -%}
    {%- elsif param.name == "ws" -%}{%- assign wind = value | round -%}
    {%- elsif param.name == "gust" -%}{%- assign gust = value | round -%}
    {%- elsif param.name == "pmean" -%}{%- assign precip = value -%}
    {%- elsif param.name == "pcat" -%}{%- assign pcat_v = value | round -%}{%- assign pcat = type[pcat_v] -%}
    {%- elsif param.name == "Wsymb2" -%}
      {%- assign wsymb2_v = value | round -%}
      {%- assign wsymb = symbol[wsymb2_v] -%}
      {%- assign icon = icons[wsymb2_v] -%}
    {%- endif -%}
  {%- endfor -%}
  {%- break -%}
{%- endfor -%}
{%- assign now_timetz = validtimetz -%}
{%- assign today_date = now_timetz | date: "%Y-%m-%d" -%}
{%- assign day_u = now_timetz | date: "%u" | plus: 0 -%}
{%- assign day = days_l[day_u] -%}
{%- assign feels_like = temp -%}
{%- if temp <= 10 and wind >= 3 -%}
  {%- assign wind_adj = wind | times: 12 | divided_by: 10 -%}
  {%- assign feels_like = temp | minus: wind_adj -%}
{%- endif -%}

<div class="title_bar">
  <span class="title">{{ day }} {{ now_timetz | date: "%Y-%m-%d" }}</span>
  <span class="instance">{{ wsymb }}</span>
</div>

<div class="layout layout--col">

  <div class="grid grid--cols-2 stretch-y">
    <div class="item">
      <div class="content flex flex--center-x">
        <span class="value value--xlarge lg:value--xxlarge" style="line-height:1.1">{{ icon }}</span>
        <span class="label lg:label--large">{{ wsymb }}</span>
      </div>
    </div>
    <div class="item">
      <div class="grid grid--cols-2">
        <div class="item">
          <div class="content flex flex--center-x">
            <span class="value value--large lg:value--xlarge value--tnums">{{ temp }}°</span>
            <span class="label">Temp °C</span>
          </div>
        </div>
        <div class="item">
          <div class="content flex flex--center-x">
            <span class="value value--large lg:value--xlarge value--tnums">{{ feels_like }}°</span>
            <span class="label">Känns</span>
          </div>
        </div>
        <div class="item">
          <div class="content flex flex--center-x">
            <span class="value value--large lg:value--xlarge value--tnums">{{ wind }}–{{ gust }}</span>
            <span class="label">Vind m/s</span>
          </div>
        </div>
        <div class="item">
          <div class="content flex flex--center-x">
            <span class="value value--large lg:value--xlarge value--tnums">{{ precip }}</span>
            <span class="label">{{ pcat | default: "Ned." }} mm</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid--cols-{{ show }} stretch-y">
    {%- for series in timeSeries -%}
      {%- assign validtimetz = series.validTime | date: "%s" | plus: trmnl.user.utc_offset -%}
      {%- assign fc_date = validtimetz | date: "%Y-%m-%d" -%}
      {%- if fc_date != today_date %}{% break %}{% endif -%}
      {%- assign hour = validtimetz | date: "%H" -%}
      {%- if hours contains hour -%}
        {%- assign i = i | plus: 1 -%}
        {%- for param in series.parameters -%}
          {%- assign value = param.values[0] | plus: 0 -%}
          {%- if param.name == "t" -%}{%- assign f_temp = value | round -%}
          {%- elsif param.name == "ws" -%}{%- assign f_wind = value | round -%}
          {%- elsif param.name == "gust" -%}{%- assign f_gust = value | round -%}
          {%- elsif param.name == "pmean" -%}{%- assign f_precip = value -%}
          {%- elsif param.name == "pcat" -%}{%- assign f_pcat_v = value | round -%}
          {%- elsif param.name == "Wsymb2" -%}
            {%- assign f_wsymb2_v = value | round -%}
            {%- assign f_icon = icons[f_wsymb2_v] -%}
          {%- endif -%}
        {%- endfor -%}
        {%- assign f_feels = f_temp -%}
        {%- if f_temp <= 10 and f_wind >= 3 -%}
          {%- assign f_wind_adj = f_wind | times: 12 | divided_by: 10 -%}
          {%- assign f_feels = f_temp | minus: f_wind_adj -%}
        {%- endif -%}
        {%- assign f_day_u = validtimetz | date: "%u" | plus: 0 -%}
        {%- assign f_day = days[f_day_u] -%}
        <div class="flex flex--col flex--center-x">
          <div class="label label--small lg:label--base label--inverted">{{ f_day }} {{ validtimetz | date: "%H:00" }}</div>
          <div class="value value--small lg:value--base" style="line-height:1.1">{{ f_icon }}</div>
          <div class="value value--xsmall lg:value--small value--tnums">{{ f_temp }}°C</div>
          <div class="value value--xsmall lg:value--small value--tnums">{{ f_feels }}°↓</div>
          <div class="value value--xxsmall lg:value--xsmall value--tnums">{{ f_wind }}–{{ f_gust }}m/s</div>
          <div class="value value--xxsmall lg:value--xsmall value--tnums">{% if f_pcat_v > 0 %}{{ f_precip }}mm{% else %}–{% endif %}</div>
        </div>
        {%- if i == show %}{% break %}{% endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>

</div>

<div class="title_bar">
  <span class="title">SMHI</span>
  <span class="instance">{{ trmnl.plugin_settings.custom_fields_values.city }}</span>
</div>
